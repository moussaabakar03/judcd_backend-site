# ==========================================
# CONFIGURATION ENVIRONNEMENT JUDCD BACKEND
# ==========================================

# Mode de l'application
DEBUG=True
ENVIRONMENT=development

# Configuration de la base de données
# Option 1: SQLite (développement)
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# Option 2: PostgreSQL (production) - Décommenter pour utiliser
# DB_ENGINE=postgresql
# DB_NAME=judcd_db
# DB_USER=judcd_user
# DB_PASSWORD=judcd_password
# DB_HOST=localhost
# DB_PORT=5432

# Configuration de l'application
SECRET_KEY=django-insecure-^!(1m8-*beb&r7%^rx)g=invc!vq)31_rem*9%9wgm(&+)^ub2
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Configuration CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Configuration JWT
JWT_SECRET_KEY=django-insecure-^!(1m8-*beb&r7%^rx)g=invc!vq)31_rem*9%9wgm(&+)^ub2
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400

# Configuration des fichiers statiques et médias
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# Configuration Email (pour la production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=judcd@gmail.com
EMAIL_HOST_PASSWORD=Judcd@2026
DEFAULT_FROM_EMAIL=judcd@gmail.com

# Superutilisateur automatique (développement uniquement)
DJANGO_SUPERUSER_USERNAME=associationjudcd@gmail.com
DJANGO_SUPERUSER_EMAIL=associationjudcd@gmail.com
DJANGO_SUPERUSER_PASSWORD=Judcd@2026

# Configuration API
API_BASE_URL=http://localhost:8000/api/v1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/django.log

# Sécurité (production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Session
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Internationalisation
LANGUAGE_CODE=fr
TIME_ZONE=Africa/Lome
USE_I18N=True
USE_L10N=True
USE_TZ=True

# Configuration PostgreSQL (si utilisé)
# psycopg2 connection string format:
# postgresql://user:password@host:port/dbname
POSTGRES_URL=postgresql://judcd_user:judcd_password@localhost:5432/judcd_db

# Configuration Redis (si utilisé pour le cache)
# REDIS_URL=redis://localhost:6379/1

# Configuration Cloudinary (si utilisé pour les images)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
